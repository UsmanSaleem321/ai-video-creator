# Copy this file to .env and fill in your values.

# Hugging Face access token (required for gated models like Stable Diffusion
# and Stable Audio Open). Get one at https://huggingface.co/settings/tokens
#
# For the cinematic pipeline (--mode cinematic), you must also visit and
# accept the license on huggingface.co (one-time, while logged in) for:
#   https://huggingface.co/stabilityai/stable-video-diffusion-img2vid-xt
#   https://huggingface.co/stabilityai/stable-video-diffusion-img2vid
# h94/IP-Adapter is public and needs no license click-through.
HF_TOKEN=hf_your_token_here

# Where the pipeline reads/writes output. Defaults to ./output if unset.
AVC_OUTPUT_DIR=./output

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
AVC_LOG_LEVEL=INFO
